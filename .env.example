# Generate .env with:
# pnpm init:env
# Use a different lowercase project name for each company/workspace/trust
# boundary when running more than one Operant stack on the same Docker host.
OPERANT_COMPOSE_PROJECT_NAME=operant

OPERANT_SECRET_KEY=

# Internal API token used by the OpenClaw SecretRef resolver.
OPERANT_INTERNAL_TOKEN=change-me-in-prod

# Shared dashboard login secret for admin sessions and first-time setup.
OPERANT_ADMIN_LOGIN_TOKEN=change-me-admin-login-token

POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgres://operant:change-me-postgres-password@postgres:5432/operant

# Optional private Redis service for future async queue workers. Leave empty for
# the default first-slice deployment; set COMPOSE_PROFILES=queue or pass
# `--profile queue` to the pnpm compose wrapper when you want Redis started.
COMPOSE_PROFILES=
REDIS_URL=redis://redis:6379/0

OPERANT_HOST=0.0.0.0
OPERANT_PORT=8080
OPERANT_HTTP_BIND=127.0.0.1
OPERANT_HTTP_PORT=8080
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
OPENCLAW_GATEWAY_HOST_BIND=127.0.0.1
OPENCLAW_GATEWAY_HOST_PORT=18789
MSTEAMS_WEBHOOK_HOST_BIND=127.0.0.1
MSTEAMS_WEBHOOK_HOST_PORT=3978
OPERANT_DEFAULT_COMPANY_NAME=Acme Inc.
OPERANT_DEFAULT_WORKSPACE_NAME=Acme Slack

OPENCLAW_VERSION=2026.5.18
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-gateway-token
OPENCLAW_GATEWAY_URL=http://openclaw-gateway:18789
OPENCLAW_CONFIG_PATH=/operant/openclaw/openclaw.json

# Base Compose must reply without a Docker socket inside the OpenClaw gateway.
# The sandbox overlay sets this to docker after it installs Docker CLI and mounts
# the dedicated host socket.
OPERANT_OPENCLAW_SANDBOX_MODE=off

# Optional Docker-backed OpenClaw sandbox overlay. Use only with
# `--file docker-compose.sandbox.yml` on a dedicated single-trust-boundary host.
# The overlay bootstraps OpenClaw's default openclaw-sandbox:bookworm-slim image
# through this socket when the image is not already present.
# This socket path is resolved by the Docker daemon, not by the Docker CLI.
# Set OPENCLAW_DOCKER_GID to the group id that owns that socket inside the
# Docker daemon host. Colima commonly uses 991; Linux hosts may differ.
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
OPENCLAW_DOCKER_GID=991

# Optional local dev override when running outside Compose.
# DATABASE_URL=postgres://operant:your-local-password@localhost:5432/operant

# Optional live verification inputs for `pnpm compose:e2e`.
# Keep real values in your private .env or shell, never in git.
# The verifier accepts the generic Slack names below or these Operant-scoped
# aliases: OPERANT_LIVE_SLACK_CHANNEL_ID, OPERANT_LIVE_SLACK_APP_TOKEN,
# OPERANT_LIVE_SLACK_BOT_TOKEN, OPERANT_LIVE_SLACK_USER_TOKEN.
# OPERANT_LIVE_ADMIN_SLACK_USER_ID=U...
# SLACK_CHANNEL_ID=C...
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...
# Optional verifier-only Slack configuration token. Use it with
# `pnpm slack:manifest-probe` to export the installed app manifest and verify
# Socket Mode, App Home Messages, events, and scopes.
# SLACK_CONFIG_TOKEN=xoxp-or-xoxe-slack-configuration-token
# SLACK_APP_ID=A...
# Optional temporary verifier-only human user OAuth token. This is not a Slack
# user ID like U..., not a bot token like xoxb-..., and not saved in Operant
# config. If omitted, use manual human-post mode below.
# SLACK_USER_TOKEN=xoxp-or-xoxc-allowed-human-user-oauth-token
# OPERANT_LIVE_DM_CHANNEL_ID=D...
# Optional distinct denied-user token/ID for two-human testing only. Acceptance
# defaults to the one-human temporary-deny proof when these are omitted.
# OPERANT_LIVE_DENIED_USER_TOKEN=xoxp-or-xoxc-denied-human-user-oauth-token
# OPERANT_LIVE_DENIED_USER_ID=U...
# Manual human-post verification alternative: omit user tokens, set the flag
# below, and have the allowed human post the verifier prompts in Slack while the
# bot token observes conversations.history/replies.
# OPERANT_LIVE_MANUAL_SLACK_POSTS=1
# OPERANT_LIVE_MANUAL_SLACK_NUDGE=1
# OPERANT_LIVE_ALLOWED_USER_ID=U...
# One-human strict denied-policy proof: temporarily deny the allowed test user
# for the no-reply probe, then restore policy before approval testing. This is
# the default strict behavior when no distinct denied user is configured.
# OPERANT_LIVE_DENIED_USE_ALLOWED_USER=1
# OPERANT_LIVE_APPROVAL_PROMPT="Use the exec tool to run exactly: echo operant-approval"
# OPENAI_API_KEY=sk-...
# Alternative model key aliases: OPERANT_LIVE_MODEL_API_KEY, MODEL_API_KEY,
# or ANTHROPIC_API_KEY. Set OPERANT_LIVE_MODEL_PROVIDER/MODEL_PROVIDER and
# OPERANT_LIVE_MODEL_NAME/MODEL_NAME when using a non-default provider/model.
# Optional customer-owned tool credential seed for compose E2E.
# Format: kind/key=ENV_VAR,kind/key=ENV_VAR
# OPERANT_LIVE_INTEGRATION_CREDENTIALS=github/api-token=GITHUB_TOKEN

# Optional Microsoft Teams live/manual verification inputs. Operators provide
# public HTTPS or a tunnel that forwards to MSTEAMS_WEBHOOK_HOST_PORT and point
# the Azure Bot Messaging Endpoint at https://<host>/api/messages.
# TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
# TEAMS_APP_PASSWORD=<teams-bot-client-secret>
# TEAMS_TENANT_ID=00000000-0000-0000-0000-000000000000
# OPERANT_LIVE_TEAMS_ALLOWED_AAD_USER_ID=00000000-0000-0000-0000-000000000000
# OPERANT_LIVE_TEAMS_TEAM_ID=19:...
# OPERANT_LIVE_TEAMS_CHANNEL_ID=19:...
# OPERANT_LIVE_TEAMS_DM_CONVERSATION_ID=19:...

# Pipedream Connect project OAuth client. With all five vars set, the Operant
# OpenClaw plugin (apps/openclaw-plugin) exposes pipedream_list_actions and
# pipedream_run_action so each Slack user OAuths their own SaaS accounts via a
# one-time connect link; if any var is missing only operant_ping registers.
# See docs/setup.md "Pipedream Connect (per-user SaaS tools)" for the full path.
OPERANT_MCP_SOURCE_PIPEDREAM_URL=https://remote.mcp.pipedream.net/v3
# PIPEDREAM_PROJECT_CLIENT_ID=                       # from Pipedream → Project → OAuth Clients
# PIPEDREAM_PROJECT_CLIENT_SECRET=                   # rotate if pasted anywhere
# PIPEDREAM_PROJECT_ID=proj_xxxxxxx                  # from your Pipedream project URL
# PIPEDREAM_ENVIRONMENT=development                  # development | production (separate token namespaces)
