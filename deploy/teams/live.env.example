# Copy to a private live env file. Never commit real Teams credentials.

TEAMS_APP_ID=00000000-0000-0000-0000-000000000000
TEAMS_APP_PASSWORD=<teams-bot-client-secret>
TEAMS_TENANT_ID=00000000-0000-0000-0000-000000000000

# Public HTTPS endpoint configured in Azure Bot Service. It must forward to the
# OpenClaw gateway webhook on MSTEAMS_WEBHOOK_HOST_PORT.
MSTEAMS_PUBLIC_MESSAGING_ENDPOINT=https://example.ngrok-free.app/api/messages

OPERANT_LIVE_TEAMS_ALLOWED_AAD_USER_ID=00000000-0000-0000-0000-000000000000
OPERANT_LIVE_TEAMS_APPROVER_AAD_USER_ID=00000000-0000-0000-0000-000000000000
OPERANT_LIVE_TEAMS_TEAM_ID=19:...
OPERANT_LIVE_TEAMS_CHANNEL_ID=19:...
OPERANT_LIVE_TEAMS_DM_CONVERSATION_ID=19:...
OPERANT_LIVE_TEAMS_CHANNEL_PROMPT="@Operant say exactly: operant teams channel ok"
OPERANT_LIVE_TEAMS_DM_PROMPT="say exactly: operant teams dm ok"
OPERANT_LIVE_TEAMS_APPROVAL_PROMPT="Use the exec tool to run exactly: echo operant-teams-approval"

