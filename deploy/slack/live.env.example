# Copy this file to a private env file, for example:
# cp deploy/slack/live.env.example .env.acme.live
#
# Fill in real values there. Do not commit the private file.
# Use this file together with a generated Compose env from `pnpm init:env`.

# Dashboard admin login token comes from the generated Compose env passed with
# --env. Keep this commented unless intentionally targeting a different stack
# than the one in the Compose env file.
# OPERANT_ADMIN_LOGIN_TOKEN=operant_admin_...

# Slack workspace and verifier identities.
OPERANT_LIVE_ADMIN_SLACK_USER_ID=U...
# Optional workspace assertion. Live preflight compares this with Slack auth.test
# team_id values for bot/test/denied tokens when provided.
# OPERANT_LIVE_SLACK_TEAM_ID=T...
SLACK_CHANNEL_ID=C...
OPERANT_LIVE_DM_CHANNEL_ID=D...
# Optional explicit IDs. Live preflight verifies these against Slack auth.test
# when provided.
# OPERANT_LIVE_BOT_USER_ID=U...
# OPERANT_LIVE_DENIED_USER_ID=U...

# Optional policy seed additions for Compose E2E. The primary channel, admin
# user, allowed test user, and admin approval approver are always included
# automatically.
# OPERANT_LIVE_ALLOWED_DM_USER_IDS=U...
# OPERANT_LIVE_ALLOWED_CHANNEL_IDS=C...
# OPERANT_LIVE_APPROVER_SLACK_USER_IDS=U...

# Slack tokens. The app-level token needs connections:write for Socket Mode.
# Slack apps.connections.open uses this app-level token to return the
# temporary WebSocket URL OpenClaw connects to for Slack events and interactive
# payloads; the bot token cannot replace it.
# Human user OAuth tokens are optional verifier-only credentials. They normally
# start with xoxp- or xoxc-. They are not Slack user IDs like U..., not bot
# tokens like xoxb-..., and not saved in Operant config. The live verifier uses
# the allowed token for auth.test and chat.postMessage; the allowed user token also posts
# into the existing DM. The bot token must be the installed app bot token;
# auth.test must return bot_id for it. It is used for conversations.info,
# conversations.members, and conversations.replies checks.
SLACK_APP_TOKEN=<slack-app-token>
SLACK_BOT_TOKEN=<slack-bot-token>
SLACK_USER_TOKEN=<xoxp-or-xoxc-allowed-human-user-oauth-token>
# Optional verifier-only Slack configuration token. Use a human/configuration
# token with app_configurations:read to export the installed app manifest via
# `pnpm slack:manifest-probe`. Add app_configurations:write only when you
# intentionally manage Slack app manifests through Slack's manifest APIs.
# SLACK_CONFIG_TOKEN=<xoxp-or-xoxe-slack-configuration-token>
# SLACK_APP_ID=A...
# Optional distinct denied user for two-human testing only. Acceptance defaults
# to a one-human temporary-deny proof when these are omitted.
# OPERANT_LIVE_DENIED_USER_TOKEN=<xoxp-or-xoxc-denied-human-user-oauth-token>
# OPERANT_LIVE_DENIED_USER_ID=U...

# Manual human-post verification alternative. Use this when you do not want to
# mint a temporary human Slack user OAuth token. The verifier prints exact
# messages for the allowed human to post, then observes them with the bot token.
# The allowed user defaults to the admin Slack user when omitted.
# OPERANT_LIVE_MANUAL_SLACK_POSTS=1
# OPERANT_LIVE_MANUAL_SLACK_NUDGE=1
# OPERANT_LIVE_ALLOWED_USER_ID=U...
# Denied-policy proof is one-human by default. Omit denied-token/denied-user-id
# to temporarily deny the allowed test user for the no-reply probe; Operant
# restores policy before the approval probe. This one-human temporary-deny proof
# is the default strict behavior when no distinct denied user is configured.
# OPERANT_LIVE_DENIED_USE_ALLOWED_USER=1

# Model key for the live OpenClaw run. Provider-specific aliases are accepted
# only for the matching provider; use a generic key alias for custom providers.
OPENAI_API_KEY=<model-api-key>
# ANTHROPIC_API_KEY=<anthropic-model-api-key>
# OPERANT_LIVE_MODEL_PROVIDER=openai
# OPERANT_LIVE_MODEL_NAME=gpt-5

# Optional harmless prompt used to exercise OpenClaw's Slack approval UI.
OPERANT_LIVE_APPROVAL_PROMPT=Use the exec tool to run exactly: echo operant-approval

# Optional customer-owned integration credentials for Compose E2E seed checks.
# Format: kind/key=ENV_VAR,kind/key=ENV_VAR
# OPERANT_LIVE_INTEGRATION_CREDENTIALS=github/api-token=GITHUB_TOKEN
# Structured JSON format for labels or generated seed files. Prefer
# secretValueEnv so raw customer secrets stay in normal private env vars.
# OPERANT_LIVE_INTEGRATION_CREDENTIALS_JSON=[{"kind":"linear","key":"api-token","label":"Linear API token","secretValueEnv":"LINEAR_API_KEY"}]
