{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "replicaCount",
    "imagePullPolicy",
    "controlPlane",
    "openclaw",
    "database",
    "redis",
    "secrets",
    "workspace",
    "storage",
    "service",
    "ingress",
    "nodeSelector",
    "tolerations",
    "affinity"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1,
      "description": "Operant runs one control-plane/OpenClaw gateway pair per company/workspace/trust boundary. Use a separate Helm release for another boundary."
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "controlPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "port", "publicPort", "resources"],
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 }
          }
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "publicPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "resources": { "type": "object" }
      }
    },
    "openclaw": {
      "type": "object",
      "additionalProperties": false,
      "required": ["image", "port", "service", "resources"],
      "properties": {
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 }
          }
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "publicPort"],
          "properties": {
            "enabled": { "type": "boolean" },
            "publicPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "resources": { "type": "object" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "existingSecret"],
      "properties": {
        "url": { "type": "string" },
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "key"],
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "existingSecret"],
      "properties": {
        "url": { "type": "string" },
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "key"],
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "existingSecret",
        "operantSecretKey",
        "operantInternalToken",
        "operantAdminLoginToken",
        "openclawGatewayToken"
      ],
      "properties": {
        "create": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "operantSecretKey": { "type": "string" },
        "operantInternalToken": { "type": "string" },
        "operantAdminLoginToken": { "type": "string" },
        "openclawGatewayToken": { "type": "string" }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["companyName", "name"],
      "properties": {
        "companyName": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["className", "openclawStateSize", "openclawConfigSize"],
      "properties": {
        "className": { "type": "string" },
        "openclawStateSize": { "type": "string", "pattern": "^[1-9][0-9]*(Mi|Gi|Ti)$" },
        "openclawConfigSize": { "type": "string", "pattern": "^[1-9][0-9]*(Mi|Gi|Ti)$" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "className", "host", "annotations", "tls"],
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "host": { "type": "string" },
        "annotations": { "type": "object" },
        "tls": { "type": "array" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
